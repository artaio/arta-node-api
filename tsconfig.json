{
  "compilerOptions": {
    "target": "es2018",
    "module": "commonjs",
    "outDir": "dist",
    "esModuleInterop": true,
    "declaration": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipDefaultLibCheck": false,
    "skipLibCheck": false,
    "resolveJsonModule": true,
    "types": ["jest"]
  },
  "include": ["lib/**/*", "test/**/*", "test-integration/**/*", "schemas/**/*"]
}
